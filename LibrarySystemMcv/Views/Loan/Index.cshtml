@model LibrarySystemMcv.Models.ViewData<LibrarySystemMcv.Models.Loan>

@{
    ViewBag.Title = "Loans";
}

<h2>Займы</h2>

@if (Model.Data.Count() > 0) {
    <p>
        @Html.ActionLink("Создать", "Create")
    </p>

    using (Html.BeginForm("ApplyFilters", null, FormMethod.Post, new { @class = "d-flex gap-4" })) {
        @Html.AntiForgeryToken()
        @Html.EditorFor(model => model.SearchSubstring, new { htmlAttributes = new { @class = "form-control", placeholder = "Поиск" } })

        @Html.DropDownListFor(model => model.SortSelector, Model.SortSelectors, null, htmlAttributes: new { @class = "form-control" })
        @Html.DropDownListFor(model => model.SortType, Model.SortTypes, null, htmlAttributes: new { @class = "form-control" })

        <input type="submit" value="Применить" class="btn btn-outline-success" />

        if (Model.Filtered) {
            <a href="/Loan/DropFilters" class="btn btn-outline-danger">
                <div class="btn-close"></div>
            </a>
        }
    }

    <table class="table">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Data[0].BookId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Data[0].ReaderId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Data[0].BorrowDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Data[0].ReturnDate)
            </th>
            <th></th>
        </tr>

        @foreach (var item in Model.GetData()) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.BookId)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ReaderId)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.BorrowDate.ToString().Split(' ')[0])
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ReturnDate.ToString().Split(' ')[0])
                </td>
                <td>
                    @Html.ActionLink("Редактировать", "Edit", new { id = item.Id }) |
                    @Html.ActionLink("Детали", "Details", new { id = item.Id }) |
                    @Html.ActionLink("Удалить", "Delete", new { id = item.Id })
                </td>
            </tr>
        }

    </table>
} else {
    <div class="alert alert-info">
        В базе данных нет займов. Хотите
        @Html.ActionLink("создать", "Create")
    </div>
}

@model LibrarySystemMcv.Models.Book

@{
    ViewBag.Title = "Details";
}

<h2>Book details</h2>

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.Title)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Title)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Author)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Author)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Year)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Year)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Quantity)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Quantity)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Available)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Available)
        </dd>

    </dl>
</div>
<p>
    @Html.ActionLink("Edit", "Edit", new { id = Model.Id }) |
    @Html.ActionLink("Back to List", "Index")
</p>

<br />
<h4>Loans</h4>
<hr />

@if (Model.Loans.Count > 0) {
    <table class="table">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Loans.ToList()[0].ReaderId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Loans.ToList()[0].BorrowDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Loans.ToList()[0].ReturnDate)
            </th>
            <th></th>
        </tr>

        @foreach (var item in Model.Loans) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.ReaderId)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.BorrowDate.ToString().Split(' ')[0])
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ReturnDate.ToString().Split(' ')[0])
                </td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = item.Id }) |
                    @Html.ActionLink("Details", "Details", new { id = item.Id }) |
                    @Html.ActionLink("Delete", "Delete", new { id = item.Id })
                </td>
            </tr>
        }
    </table>
}
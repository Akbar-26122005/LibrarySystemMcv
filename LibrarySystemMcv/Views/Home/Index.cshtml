@model LibrarySystemMcv.Controllers.DashboardViewModel
@{
    ViewBag.Title = "Library Management System";
}

<div class="container-fluid">
    <!-- Заголовок и приветствие -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="jumbotron bg-primary text-white p-5 rounded">
                <h1 class="display-4">📚 Library Management System</h1>
                <p class="lead">Управляйте вашей библиотекой эффективно и удобно</p>
                <hr class="my-4">
                <p>Система для учета книг, читателей и выдачи литературы</p>
            </div>
        </div>
    </div>

    <!-- Статистика -->
    <div class="row mb-5">
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-info h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@Model.Stats.TotalBooks</h4>
                            <p class="card-text">Всего книг</p>
                        </div>
                        <div class="display-4">📖</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-white bg-success h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@Model.Stats.TotalReaders</h4>
                            <p class="card-text">Зарегистрированных читателей</p>
                        </div>
                        <div class="display-4">👥</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-white bg-warning h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@Model.Stats.ActiveLoans</h4>
                            <p class="card-text">Активных выдач</p>
                        </div>
                        <div class="display-4">📋</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-white bg-danger h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@Model.Stats.OverdueLoans</h4>
                            <p class="card-text">Просроченных выдач</p>
                        </div>
                        <div class="display-4">⏰</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Быстрые действия -->
    <div class="row mb-5">
        <div class="col-12">
            <h3 class="mb-4">Быстрые действия</h3>
            <div class="d-grid gap-2 d-md-flex justify-content-md-start">
                @Html.ActionLink("📖 Добавить книгу", "Create", "Book", null, new { @class = "btn btn-primary btn-lg me-md-2" })
                @Html.ActionLink("👥 Добавить читателя", "Create", "Reader", null, new { @class = "btn btn-success btn-lg me-md-2" })
                @Html.ActionLink("📋 Новая выдача", "Create", "Loan", null, new { @class = "btn btn-warning btn-lg me-md-2" })
                @Html.ActionLink("📊 Все выдачи", "Index", "Loan", null, new { @class = "btn btn-info btn-lg" })
                @Html.ActionLink("Скачать в JSON", "DownloadJson", "Home", null, new { @class = "btn btn-secondary" })
            </div>
        </div>
    </div>

    <!-- Последние выдачи -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title mb-0">📋 Последние выдачи книг</h4>
                </div>
                <div class="card-body">
                    @if (Model.RecentLoans.Any()) {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Книга</th>
                                        <th>Читатель</th>
                                        <th>Дата выдачи</th>
                                        <th>Статус</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var loan in Model.RecentLoans) {
                                        <tr>
                                            <td>@loan.Book.Title</td>
                                            <td>@loan.Reader.Name</td>
                                            <td>@loan.BorrowDate.ToString("dd.MM.yyyy")</td>
                                            <td>
                                                @if (loan.ReturnDate.HasValue) {
                                                    <span class="badge bg-success">Возвращена</span>
                                                } else if (loan.BorrowDate < DateTime.Now.AddDays(-30)) {
                                                    <span class="badge bg-danger">Просрочена</span>
                                                } else {
                                                    <span class="badge bg-warning">На руках</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        @Html.ActionLink("Посмотреть все выдачи →", "Index", "Loan", null, new { @class = "btn btn-outline-primary" })
                    } else {
                        <div class="text-center py-4">
                            <div class="display-1 text-muted">📚</div>
                            <h5 class="text-muted">Нет данных о выдачах</h5>
                            <p class="text-muted">Начните работу с создания первой выдачи книги</p>
                            @Html.ActionLink("Создать первую выдачу", "Create", "Loan", null, new { @class = "btn btn-primary" })
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Информационные блоки -->
    <div class="row mt-5">
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="display-1 text-primary">⚡</div>
                    <h5 class="card-title">Быстрый доступ</h5>
                    <p class="card-text">Мгновенный поиск книг и читателей с помощью умной системы поиска</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="display-1 text-success">📊</div>
                    <h5 class="card-title">Аналитика</h5>
                    <p class="card-text">Детальная статистика и отчеты по активности библиотеки</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="display-1 text-warning">🔔</div>
                    <h5 class="card-title">Уведомления</h5>
                    <p class="card-text">Автоматическое оповещение о просроченных книгах</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .jumbotron {
        background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
    }

    .card {
        transition: transform 0.2s;
        border: none;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        }

    .display-4 {
        font-size: 3.5rem;
    }
</style>
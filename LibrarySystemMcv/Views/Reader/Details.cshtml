@model LibrarySystemMcv.Models.Reader

@{
    ViewBag.Title = "Reader Details";
}

<h2>Детали про читателя</h2>

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.Name)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Name)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Phone)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Phone)
        </dd>

    </dl>
</div>
<p>
    @Html.ActionLink("Редактировать", "Edit", new { id = Model.Id }) |
    @Html.ActionLink("Назад к списку", "Index")
</p>


@if (Model.Loans.Count > 0) {
    <br />
    <h4>Loans</h4>
    <hr />

    <table class="table">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Loans.ToList()[0].BookId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Loans.ToList()[0].BorrowDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Loans.ToList()[0].ReturnDate)
            </th>
            <th></th>
        </tr>

        @foreach (var item in Model.Loans) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.BookId)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.BorrowDate.ToString().Split(' ')[0])
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ReturnDate.ToString().Split(' ')[0])
                </td>
                <td>
                    @Html.ActionLink("Редактировать", "Edit", new { id = item.Id }) |
                    @Html.ActionLink("Детали", "Details", new { id = item.Id }) |
                    @Html.ActionLink("Удалить", "Delete", new { id = item.Id })
                </td>
            </tr>
        }
    </table>
}
@model LibrarySystemMcv.Models.ViewData<LibrarySystemMcv.Models.Reader>

@{
    ViewBag.Title = "Readers";
}

<h2>Читатели</h2>

@if (Model.Data.Count() > 0) {
    <p>
        @Html.ActionLink("Добавить", "Create")
    </p>

    using (Html.BeginForm("ApplyFilters", null, FormMethod.Post, new { @class = "d-flex gap-4" })) {
        @Html.AntiForgeryToken()
        @Html.EditorFor(model => model.SearchSubstring, new { htmlAttributes = new { @class = "form-control", placeholder = "Поиск" } })

        @Html.DropDownListFor(model => model.SortSelector, Model.SortSelectors, null, htmlAttributes: new { @class = "form-control" })
        @Html.DropDownListFor(model => model.SortType, Model.SortTypes, null, htmlAttributes: new { @class = "form-control " })

        <input type="submit" value="Применить" class="btn btn-outline-success" />

        if (Model.Filtered) {
            <a href="/Reader/DropFilters" class="btn btn-outline-danger">
                <div class="btn-close"></div>
            </a>
        }
    }

    <table class="table">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Data[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Data[0].Phone)
            </th>
            <th></th>
        </tr>

    @foreach (var item in Model.GetData()) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Phone)
            </td>
            <td>
                @Html.ActionLink("Редактировать", "Edit", new { id = item.Id }) |
                @Html.ActionLink("Детали", "Details", new { id = item.Id }) |
                @Html.ActionLink("Удалить", "Delete", new { id = item.Id })
            </td>
        </tr>
    }

    </table>
} else {
    <div class="alert alert-info">
        В базе данных нет читателей. Хотите
        @Html.ActionLink("создать", "Create")
    </div>
}